{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Server=.;Database=KoralyticsDb;Trusted_Connection=True;MultipleActiveResultSets=true;TrustServerCertificate=True"
